{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Atlas Document Output",
  "type": "object",
  "required": [
    "schema_version",
    "document_id",
    "title",
    "status",
    "version",
    "sections",
    "dependencies_used",
    "open_questions"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "document_id": {
      "type": "string",
      "pattern": "^[A-Z]{2,3}-[0-9]{3}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "draft",
        "review_required",
        "approved",
        "canonical",
        "rejected"
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "sections": {
      "type": "object",
      "required": [
        "purpose",
        "scope",
        "context",
        "definitions",
        "architecture",
        "entities",
        "fields",
        "relationships",
        "business_rules",
        "workflows",
        "validation",
        "permissions",
        "integrations",
        "failure_scenarios",
        "security",
        "seo_impact",
        "ai_usage",
        "wordpress_mapping",
        "examples",
        "acceptance_criteria",
        "dependencies_used",
        "related_documents",
        "open_questions",
        "change_history"
      ],
      "properties": {
        "purpose": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "minLength": 1 },
        "context": { "type": "string", "minLength": 1 },
        "definitions": { "type": "string", "minLength": 1 },
        "architecture": { "type": "string", "minLength": 1 },
        "entities": { "type": "string", "minLength": 1 },
        "fields": { "type": "string", "minLength": 1 },
        "relationships": { "type": "string", "minLength": 1 },
        "business_rules": { "type": "string", "minLength": 1 },
        "workflows": { "type": "string", "minLength": 1 },
        "validation": { "type": "string", "minLength": 1 },
        "permissions": { "type": "string", "minLength": 1 },
        "integrations": { "type": "string", "minLength": 1 },
        "failure_scenarios": { "type": "string", "minLength": 1 },
        "security": { "type": "string", "minLength": 1 },
        "seo_impact": { "type": "string", "minLength": 1 },
        "ai_usage": { "type": "string", "minLength": 1 },
        "wordpress_mapping": { "type": "string", "minLength": 1 },
        "examples": { "type": "string", "minLength": 1 },
        "acceptance_criteria": { "type": "string", "minLength": 1 },
        "dependencies_used": { "type": "string", "minLength": 1 },
        "related_documents": { "type": "string", "minLength": 1 },
        "open_questions": { "type": "string", "minLength": 1 },
        "change_history": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "dependencies_used": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "entities_referenced": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rules_referenced": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
