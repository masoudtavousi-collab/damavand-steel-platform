            "version": 2
          },
          "conditions": [
            {
              "id": "8c9143e8-85be-4192-94d6-39e27c097bb9",
              "leftValue": "={{$json.repair_validation.passed}}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "3c6f3840-2b51-4916-be4d-67da0fd7166e",
      "name": "Repair Passed?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        740,
        -80
      ]
    },
    {
      "parameters": {
        "jsCode": "return [{json:{...$json,status:'repair_passed',execution_mode:$json.pipeline?.execution_mode || 'OFFLINE',write_performed:false}}];"
      },
      "id": "3fff9bc4-745a-4e18-b3ad-61be196c2427",
      "name": "Return Repaired Document",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
