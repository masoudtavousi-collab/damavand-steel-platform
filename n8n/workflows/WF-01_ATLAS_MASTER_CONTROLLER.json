      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        -780,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const allowed = new Set(['OFFLINE', 'VALIDATE', 'DRY_RUN', 'LIVE']);\nconst requested = $json.execution_mode;\nconst executionMode = typeof requested === 'string' && allowed.has(requested) ? requested : 'OFFLINE';\nreturn [{json:{\n  ...$json,\n  execution_mode: executionMode,\n  dry_run: $json.dry_run === false ? false : true,\n  founder_write_approved: $json.founder_write_approved === true,\n  credentials_configured: $json.credentials_configured === true\n}}];"
      },
      "id": "33ec4dd5-5131-43fb-8ddf-114ab8374dc4",
      "name": "Resolve Execution Mode",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -560,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "21b7f648-ef90-4444-9bf4-fb8ec361b721",
              "leftValue": "={{ $json.execution_mode === 'DRY_RUN' || $json.execution_mode === 'LIVE' }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "6fc68319-dc92-48a1-8cab-7b6c95ce07f2",
      "name": "Network Execution Mode?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        -340,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const mode = $json.execution_mode === 'VALIDATE' ? 'VALIDATE' : 'OFFLINE';\nreturn [{json:{\n  status: mode === 'VALIDATE' ? 'validate_local_only' : 'offline_local_only',\n  execution_mode: mode,\n  network_performed: false,\n  write_performed: false,\n  local_validation_required: true,\n  validation_scope: ['manifest', 'registry', 'schema', 'workflows', 'secrets', 'execution_mode'],\n  validation_command: 'python3 scripts/validate_manifest.py'\n}}];"
      },
      "id": "42994ec7-9596-462c-8bef-7db635f9bf61",
      "name": "Return Local Validation Mode",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -100,
        120
      ]
    },
    {
      "parameters": {
        "url": "=https://api.github.com/repos/{{$json.github_owner}}/{{$json.github_repo}}/contents/{{$json.manifest_path}}?ref={{$json.branch}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Accept",
              "value": "application/vnd.github+json"
            },
            {
              "name": "X-GitHub-Api-Version",
              "value": "2022-11-28"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.GITHUB_TOKEN}}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "16228c0a-563f-412d-ac27-7e7e4a191e3e",
      "name": "Fetch Manifest From GitHub",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -100,
        -80
      ]
    },
    {
      "parameters": {
        "jsCode": "const cfg = $('Pipeline Configuration').first().json;\nconst encoded = ($json.content || '').replace(/\\n/g, '');\nif (!encoded) throw new Error('GitHub response did not contain manifest content.');\nconst manifest = JSON.parse(Buffer.from(encoded, 'base64').toString('utf8'));\nreturn [{json: {...cfg, manifest}}];"
      },
      "id": "3c55a745-4ec4-45c2-af61-9bee1f46ee00",
      "name": "Decode Manifest",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -300,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const cfg = $json;\nconst pending = (cfg.manifest.documents || []).filter(d => d.status === 'pending');\nif (!pending.length) return [];\nreturn pending.map(d => ({json: {\n  ...d,\n  pipeline: {\n    github_owner: cfg.github_owner,\n    github_repo: cfg.github_repo,\n    branch: cfg.branch,\n    manifest_path: cfg.manifest_path,\n    execution_mode: cfg.execution_mode,\n    dry_run: cfg.dry_run,\n    founder_write_approved: cfg.founder_write_approved,\n    credentials_configured: cfg.credentials_configured,\n    generator_workflow_id: cfg.generator_workflow_id\n  }\n}}));"
      },
      "id": "397bfdf8-ab99-405d-839b-a36657d75987",
      "name": "Select Pending Documents",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -60,
        0
      ]
    },
    {
