    {
      "parameters": {
        "jsCode": "const items = $input.all();\nreturn [{json:{\n  completed_at: new Date().toISOString(),\n  processed_documents: items.length,\n  results: items.map(i => ({id:i.json.document_id || i.json.id, status:i.json.status, validation:i.json.validation_status, write_performed:i.json.write_performed === true}))\n}}];"
      },
      "id": "187cf2cf-1c92-43a1-9622-be9fc9145666",
