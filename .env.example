APP_ENV=development
APP_URL=http://localhost:8080
APP_LOCALE=fa_IR
APP_TIMEZONE=Asia/Tehran

DB_HOST=db
DB_PORT=3306
DB_NAME=damavand_steel
DB_USER=wordpress
DB_PASSWORD=change-me
DB_TABLE_PREFIX=wp_

WP_DEBUG=true
WP_DEBUG_LOG=true
WP_DEBUG_DISPLAY=false
WP_DISABLE_CRON=false
WP_CACHE=false
DISALLOW_FILE_EDIT=true
DISALLOW_FILE_MODS=false

# Generate unique values per environment; never commit real keys.
AUTH_KEY=replace-me
SECURE_AUTH_KEY=replace-me
LOGGED_IN_KEY=replace-me
NONCE_KEY=replace-me
AUTH_SALT=replace-me
SECURE_AUTH_SALT=replace-me
LOGGED_IN_SALT=replace-me
NONCE_SALT=replace-me

# Licensed products: store keys in the deployment secret manager only.
BLOCKSY_PRO_LICENSE_KEY=
ELEMENTOR_PRO_LICENSE_KEY=
